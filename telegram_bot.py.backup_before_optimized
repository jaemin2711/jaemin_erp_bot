        lines.append(
            f"{display_no:02d} | {production_date[5:] if len(production_date) >= 10 else production_date} | "
            f"{code} | {name} | {qty}kg"
        )

        original_idx = int(row.get("_원본index", display_no - 1))
        token = make_plan_token(session, row, original_idx)
