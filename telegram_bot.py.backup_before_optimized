def load_product_aliases():
    PRODUCT_ALIAS_FILE.parent.mkdir(exist_ok=True)
    if not PRODUCT_ALIAS_FILE.exists():
        return []
    rows = []
    try:
        with open(PRODUCT_ALIAS_FILE, "r", newline="", encoding="utf-8-sig") as f:
            reader = csv.DictReader(f)
            for row in reader:
                alias = str(row.get("alias", "")).strip()
                product_code = str(row.get("product_code", "")).strip()
                product_name = str(row.get("product_name", "")).strip()
                if alias and (product_code or product_name):
                    rows.append({
                        "alias": alias,
                        "product_code": product_code,
                        "product_name": product_name,
                        "created_at": str(row.get("created_at", "")).strip(),
                        "created_by": str(row.get("created_by", "")).strip(),
                    })
    except Exception:
        return []
    return rows


def save_product_aliases(rows):
    PRODUCT_ALIAS_FILE.parent.mkdir(exist_ok=True)
    with open(PRODUCT_ALIAS_FILE, "w", newline="", encoding="utf-8-sig") as f:
        fieldnames = ["alias", "product_code", "product_name", "created_at", "created_by"]
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        for row in rows:
            writer.writerow({
                "alias": row.get("alias", ""),
                "product_code": row.get("product_code", ""),
                "product_name": row.get("product_name", ""),
                "created_at": row.get("created_at", ""),
                "created_by": row.get("created_by", ""),
            })


def find_product_alias(alias: str):
    key = normalize_candidate_text(alias)
    if not key:
        return None
    for row in load_product_aliases():
        if normalize_candidate_text(row.get("alias")) == key:
            return row
    return None


def apply_product_aliases_to_question(question: str) -> str:
    text = str(question or "")
    aliases = load_product_aliases()
    aliases.sort(key=lambda x: len(str(x.get("alias", ""))), reverse=True)

    for row in aliases:
        alias = str(row.get("alias", "")).strip()
        target = str(row.get("product_code") or row.get("product_name") or "").strip()
        if not alias or not target:
            continue
        try:
            pattern = re.compile(re.escape(alias), flags=re.IGNORECASE)
            text = pattern.sub(target, text)
        except Exception:
            if alias in text:
                text = text.replace(alias, target)
    return text


