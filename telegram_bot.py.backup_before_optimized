        data,
        user_id=update.effective_user.id,
        username=update.effective_user.username,
    )

    try:
        save_usage_log(
            update.effective_user.id,
            update.effective_user.username,
            f"계약생산등록:{data.get('제품명')} {fmt_num(data.get('월생산수량kg'))}kg",
